<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Proyect Blueprint Builder</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

  <!-- Landing screen -->
  <div id="landing" class="landing">
    <div class="landing-card">
      <div class="landing-icon">🏗️</div>
      <h1>Proyect Blueprint Builder</h1>
      <p>Transform your software idea into a complete, implementation-ready specification pack — guided step by step by
        an AI architect.</p>
      <ul class="landing-features">
        <li>✦ 18-stage structured process</li>
        <li>✦ Generates all spec documents automatically</li>
        <li>✦ Download your complete spec pack as ZIP</li>
      </ul>
      <button id="start-btn" class="btn-primary">Start Building →</button>
    </div>
  </div>

  <!-- Chat screen -->
  <div id="chat-screen" class="chat-screen hidden">

    <!-- Header -->
    <div class="chat-header">
      <div class="chat-header-left">
        <div class="avatar">🏗️</div>
        <div class="chat-header-info">
          <div class="chat-header-name">Proyect Blueprint Builder</div>
          <div class="chat-header-status" id="header-status">online</div>
        </div>
      </div>
      <div class="chat-header-right">
        <div class="stage-badge" id="stage-badge">Stage 1 / 18</div>

        <button id="download-btn" class="btn-download hidden" title="Download spec pack">
          ⬇ Download ZIP
        </button>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="progress-bar-wrap">
      <div class="progress-bar" id="progress-bar" style="width: 0%"></div>
    </div>

    <!-- Messages -->
    <div class="messages" id="messages"></div>

    <!-- Input -->
    <div class="chat-input-area">
      <textarea id="message-input" class="message-input" placeholder="Type a message…" rows="1" disabled></textarea>
      <button id="send-btn" class="send-btn" disabled>
        <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
        </svg>
      </button>
    </div>

  </div>

  <script src="/js/chat.js"></script>
</body>

</html>
# ─────────────────────────────────────────────
# AI Provider — pick ONE and set its key
# ─────────────────────────────────────────────

# Provider: anthropic | openai | gemini
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash


# ─────────────────────────────────────────────
# Database — sqlite | redis
# ─────────────────────────────────────────────
DB_TYPE=sqlite

# SQLite — no extra config needed, DB file is created at data/blueprint.db

# Redis — only used when DB_TYPE=redis
# Full URL (takes precedence over individual fields below)
# Examples:
#   redis://localhost:6379
#   redis://:password@localhost:6379
#   rediss://user:password@host:6380    ← TLS (Upstash, Redis Cloud, etc.)
REDIS_URL=redis://localhost:6379

# Or configure individually (used only if REDIS_URL is not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# TTLs (in seconds) — used by both adapters
REDIS_TTL_SESSION=604800    # 7 days  — chat messages + session metadata
REDIS_TTL_FILES=172800      # 2 days  — generated spec documents

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# AES-256-GCM key for encrypting user API keys in storage
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-char-hex-string
